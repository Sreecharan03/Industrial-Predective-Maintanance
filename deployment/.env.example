# Copy to deployment/.env and fill in. NEVER commit the real .env.

# ── Paths (absolute paths recommended on a server) ──────────────────
# Where all state lives — DB, artifacts, live CSVs. MUST be on persistent disk.
SM_DATA=/opt/senseminds-data
# The processed machine CSVs (only Datasets/processed/*.csv is needed, ~31 MB)
SM_DATASETS=/opt/senseminds-datasets

# Postgres
POSTGRES_PASSWORD=change-me-strong

# API auth (change both in any real deployment)
SENSEMINDS_JWT_SECRET=change-me-to-a-long-random-string
SENSEMINDS_DEFAULT_ADMIN_PASSWORD=change-me

# LLM (leave GROQ key empty to use the offline deterministic stub)
SENSEMINDS_GROQ_API_KEY=
SENSEMINDS_LLM_MODEL=llama-3.3-70b-versatile

# Worker
SENSEMINDS_WORKER_INTERVAL_SECONDS=300
SENSEMINDS_BOOTSTRAP_ON_START=true

# Runtime
SENSEMINDS_ENVIRONMENT=prod
SENSEMINDS_LOG_LEVEL=INFO
